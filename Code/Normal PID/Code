#include <QTRSensors.h>

QTRSensors qtr;

// ===== TB6612 Motor Driver Pins =====
#define BIN2 9
#define AIN2 2
#define PWMA 4
#define BIN1 7
#define AIN1 3
#define PWMB 6
#define STBY 5

const uint8_t SensorCount = 16;
uint16_t sensorValues[SensorCount];
const uint8_t sensors[16] = {A0, A1, A2, A3, A4, A5, A6, A7,
                             A8, A9, A12, A13, A14, A15, A16, A17};

// PID Constants
float Kp = 3.3;
float Kd = 0.29;
int baseSpeed = 180;
int lastError = 0;
#define MAX_SPEED 180

void setMotors(int leftSpeed, int rightSpeed) {
  // Left Motor (Motor A)
  if(leftSpeed >= 0) {
    digitalWrite(AIN1, LOW);
    digitalWrite(AIN2, HIGH);
    analogWrite(PWMA, leftSpeed);
  } else {
    digitalWrite(AIN1, HIGH);
    digitalWrite(AIN2, LOW);
    analogWrite(PWMA, -leftSpeed);
  }
  
  // Right Motor (Motor B)
  if(rightSpeed >= 0) {
    digitalWrite(BIN1, LOW);
    digitalWrite(BIN2, HIGH);
    analogWrite(PWMB, rightSpeed);
  } else {
    digitalWrite(BIN1, HIGH);
    digitalWrite(BIN2, LOW);
    analogWrite(PWMB, -rightSpeed);
  }
}

void setup() {
  Serial.begin(9600);
  
  // Motor pins
  pinMode(AIN1, OUTPUT);
  pinMode(AIN2, OUTPUT);
  pinMode(PWMA, OUTPUT);
  pinMode(BIN1, OUTPUT);
  pinMode(BIN2, OUTPUT);
  pinMode(PWMB, OUTPUT);
  pinMode(STBY, OUTPUT);
  
  digitalWrite(STBY, HIGH);
  
  // Sensor setup
  for(int i = 0; i < 16; i++) {
    pinMode(sensors[i], INPUT);
  }
  
  qtr.setTypeRC();
  qtr.setSensorPins(sensors, SensorCount);
  
  Serial.println("Calibrating...");
  
  // Calibrate for 5 seconds
  for (uint16_t i = 0; i < 250; i++) {
    qtr.calibrate();
    delay(20);
  }
  
  Serial.println("Calibration complete!");
  delay(1000);
}

void loop() {
  // Read sensor position (0-15000, center = 7500)
  uint16_t position = qtr.readLineBlack(sensorValues);
  
  // Calculate error from center
  int error = position - 7500;
  
  // PD control
  int motorSpeed = Kp * error + Kd * (error - lastError);
  
  // Calculate individual motor speeds
  int rightMotorSpeed = baseSpeed - motorSpeed;
  int leftMotorSpeed = baseSpeed + motorSpeed;
  
  // Constrain to max speed
  rightMotorSpeed = constrain(rightMotorSpeed, 0, MAX_SPEED);
  leftMotorSpeed = constrain(leftMotorSpeed, 0, MAX_SPEED);
  
  // Apply to motors
  setMotors(leftMotorSpeed, rightMotorSpeed);
  
  // Print debug info
  Serial.print("Pos: ");
  Serial.print(position);
  Serial.print(" | Error: ");
  Serial.print(error);
  Serial.print(" | Correction: ");
  Serial.print(motorSpeed);
  Serial.print(" | L: ");
  Serial.print(leftMotorSpeed);
  Serial.print(" | R: ");
  Serial.println(rightMotorSpeed);
  
  lastError = error;
  delay(10);
}
